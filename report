\subsubsection{Algorithmic Description}

The complete model process consists of four sequential phases: controller pre-training, two-stage plant training, closed-loop inference, and the detection-classification layer. Figure~\ref{fig:OVERVIEW_ARCHITECTURE} shows the data flow across all components; the algorithms below formalise each phase.

\textbf{Phase 1 — Controller pre-training.}
Each of the five loop controllers (PC, LC, FC, TC, CC) is trained independently on its own loop's signals. The controller receives a 300-second history of its setpoint (SP), process variable (PV), control variable (CV), and three causally-selected auxiliary channels, and is trained to autoregressively predict the CV sequence over the 180-second target horizon. Controllers are trained to convergence and their weights are frozen before plant training begins.

\textbf{Phase 2 — Two-stage plant training.}
The GRU plant model is trained in two sequential stages using the frozen controller outputs as inputs. In both stages, scheduled sampling is applied to the decoder: with probability $\alpha$ (ramped linearly from 0 to 0.483), the model feeds its own previous prediction as the next decoder input instead of the ground-truth PV, progressively bridging the training/inference gap.

In \textit{Stage 1}, all attack windows are penalised at $3\times$ the normal weight, with an additional $2\times$ weight on the TIT03 channel. This teaches the plant model to recognise that attack windows require more careful reconstruction, without yet distinguishing between attack types.

In \textit{Stage 2}, the best Stage 1 checkpoint is loaded and fine-tuned with per-scenario loss weights (Table~\ref{tab:scenario_weights}), which are calibrated to each attack type's frequency and difficulty. This refines the model's sensitivity to each specific attack regime. The plant model's scenario embedding — a learned 32-dimensional vector per scenario label — is updated in both stages, allowing a single model to condition on the operating regime without requiring separate instances per scenario.

\textbf{Phase 3 — Closed-loop inference.}
At inference time, the five controllers independently predict their CV sequences from the observed sensor history. These generated CVs are injected into the plant model's target-window input. The plant encoder then encodes the full observed CV history concatenated with the scenario embedding, and the decoder autoregressively rolls out all five PV predictions over 180 steps — feeding each prediction as the next decoder input. No runtime feedback flows from the plant back to the controllers; the closed-loop dynamics are captured entirely through the training data.

\textbf{Phase 4 — Detection and classification.}
The predicted PV trajectories are compared against actual sensor readings to produce per-window anomaly scores. A binary alert is raised when the mean absolute residual exceeds the detection threshold calibrated on normal validation windows. Simultaneously, a 30-dimensional feature vector is extracted from the residual trajectory and passed to the Random Forest classifier — trained on balanced synthetic data — which assigns one of four scenario labels (Normal, AP\_no, AP\_with, AE\_no). Together, these two outputs give the operator both an immediate alert and an attack type identification without requiring any retraining of the plant model.

Algorithms~\ref{alg:training}, \ref{alg:inference}, and \ref{alg:detection_classification} formalise Phases 2, 3, and 4 respectively.

\begin{algorithm}[H]
\caption{Two-Stage Digital Twin Training}
\label{alg:training}
\begin{algorithmic}[1]
\Require Dataset $\mathcal{D} = \{(X_b, Y_b, s_b)\}_{b=1}^{N}$,
         baseline checkpoint $\theta_0$,
         scenario weights $\{w_s\}$,
         stage configs $(\eta^{(1)}, E^{(1)}, P^{(1)})$,
         $(\eta^{(2)}, E^{(2)}, P^{(2)})$
\Ensure  Final model parameters $\phi^*$

\Statex \textbf{--- Stage 1: Causal Plant Training ---}
\State Initialise plant $f_\phi$ from baseline $\theta_0$;
       initialise controllers $\{g_{\psi_\ell}\}$ randomly
\State $\phi^* \leftarrow \phi$;\; $\text{best} \leftarrow \infty$;\;
       $p \leftarrow 0$

\For{$e = 1$ \textbf{to} $E^{(1)}$}
    \State $\alpha \leftarrow \text{SS-ratio}(e,\; e_{\rm start}{=}10,\;
           e_{\rm end}{=}59,\; \alpha_{\max}{=}0.483)$
           \Comment{scheduled sampling ratio}
    \For{each mini-batch $\mathcal{B} \sim \mathcal{D}$}
        \State Train controllers: $\psi_\ell \leftarrow \psi_\ell -
               \eta^{(1)}_{\rm ctrl}\,\nabla_{\psi_\ell}
               \mathcal{L}_{\rm ctrl}(\mathcal{B})$
        \State Compute plant predictions with SS ratio $\alpha$:
               $\hat{Y} = f_\phi(X, s,\, Y;\,\alpha)$
        \State Compute weighted loss (Eq.~\ref{eq:stage1_loss}):
               $w_b = 3$ if $s_b > 0$ else $1$
        \State $\phi \leftarrow \phi - \eta^{(1)}_{\rm plant}\,
               \nabla_\phi\,\mathcal{L}_{\rm plant}$
    \EndFor
    \State $v \leftarrow \text{ValidationLoss}(f_\phi,\, \mathcal{D}_{\rm val})$
    \If{$v < \text{best}$}
        \State $\phi^* \leftarrow \phi$;\; $\text{best} \leftarrow v$;\;
               $p \leftarrow 0$
    \Else
        \State $p \leftarrow p + 1$
        \If{$p \geq P^{(1)}$} \textbf{break} \EndIf
    \EndIf
    \State Update LR schedulers with $v$
\EndFor

\Statex \textbf{--- Stage 2: Per-Scenario Fine-Tuning ---}
\State Load $\phi \leftarrow \phi^*$;\;
       $\text{best} \leftarrow \infty$;\; $p \leftarrow 0$

\For{$e = 1$ \textbf{to} $E^{(2)}$}
    \State $\alpha \leftarrow \text{SS-ratio}(e,\; e_{\rm start}{=}0,\;
           e_{\rm end}{=}20,\; \alpha_{\max}{=}0.483)$
    \For{each mini-batch $\mathcal{B} \sim \mathcal{D}$}
        \State $\hat{Y} = f_\phi(X, s,\, Y;\,\alpha)$
        \State Compute per-scenario weighted loss (Eq.~\ref{eq:stage2_loss}):
               $w_b = w_{s_b}$ from Table~\ref{tab:scenario_weights}
        \State $\phi \leftarrow \phi -
               \eta^{(2)}_{\rm plant}\,\nabla_\phi\,\mathcal{L}_{\rm plant}$
    \EndFor
    \State $v \leftarrow \text{ValidationLoss}(f_\phi,\, \mathcal{D}_{\rm val})$
    \If{$v < \text{best}$}
        \State $\phi^* \leftarrow \phi$;\; $\text{best} \leftarrow v$;\;
               $p \leftarrow 0$
    \Else
        \State $p \leftarrow p + 1$
        \If{$p \geq P^{(2)}$} \textbf{break} \EndIf
    \EndIf
    \State Update LR schedulers with $v$
\EndFor
\State \Return $\phi^*$
\end{algorithmic}
\end{algorithm}

\begin{algorithm}[H]
\caption{Closed-Loop Inference}
\label{alg:inference}
\begin{algorithmic}[1]
\Require Observed sensor window $x_{cv} \in \mathbb{R}^{T_{\rm in} \times d}$,
         target CV window $x_{cv}^{\rm tgt} \in \mathbb{R}^{T \times d}$,
         initial PV $\mathbf{y}_0 \in \mathbb{R}^{n_{\rm pv}}$,
         scenario label $s \in \{0,1,2,3\}$,
         trained plant $f_{\phi^*}$,
         trained controllers $\{g_{\psi^*_\ell}\}_{\ell \in \mathcal{L}}$
\Ensure  PV prediction sequence
         $\hat{Y} = [\hat{\mathbf{y}}_1, \ldots, \hat{\mathbf{y}}_T]$

\Statex \textbf{Step 1: Controller rollout (independent, open-loop)}
\For{each loop $\ell \in \{\text{PC, LC, FC, TC, CC}\}$}
    \State $\hat{c}^\ell_{1:T} \leftarrow g_{\psi^*_\ell}(X^\ell)$
           \Comment{predict CV sequence from loop history}
    \State Inject into target window:
           $x_{cv}^{\rm tgt}[\,:,\, \text{col}(\ell)] \leftarrow \hat{c}^\ell_{1:T}$
\EndFor

\Statex \textbf{Step 2: Plant encoder}
\State $\mathbf{e}_s \leftarrow \text{Embedding}(s)$
       \Comment{scenario embedding $\in \mathbb{R}^{32}$}
\State $\mathbf{h}_0 \leftarrow \text{GRU}_{\rm enc}
       \bigl([x_{cv} \,\|\, \mathbf{e}_s]\bigr)$
       \Comment{encode observed history}

\Statex \textbf{Step 3: Autoregressive plant decoder}
\State $\mathbf{y} \leftarrow \mathbf{y}_0$
\For{$t = 1$ \textbf{to} $T$}
    \State $\mathbf{h}_t,\, \mathbf{o}_t \leftarrow
           \text{GRU}_{\rm dec}
           \bigl([x_{cv,t}^{\rm tgt} \,\|\, \mathbf{y}],\;
           \mathbf{h}_{t-1}\bigr)$
    \State $\hat{\mathbf{y}}_t \leftarrow \text{FC}(\mathbf{o}_t)$
           \Comment{project hidden state to 5 PV outputs}
    \State $\mathbf{y} \leftarrow \hat{\mathbf{y}}_t$
           \Comment{feed prediction as next decoder input}
\EndFor
\State \Return $[\hat{\mathbf{y}}_1, \ldots, \hat{\mathbf{y}}_T]$
\end{algorithmic}
\end{algorithm}


\subsubsection{Detection and Classification Layer}
\label{sec:detection_classification}

The trained GRU plant model is paired with a two-component detection and identification layer that operates entirely on prediction residuals, without modifying the underlying forecaster. The two components answer different questions: the detector answers \emph{whether} an anomaly is present; the classifier answers \emph{which} attack type it is.

\paragraph{Stage 1 — Binary Anomaly Detector.}
For each test window, the mean absolute PV residual is computed as a scalar anomaly score:
\begin{equation}
    s_w = \frac{1}{T \cdot K} \sum_{t=1}^{T} \sum_{k=1}^{K} \left| \hat{y}_{w,t,k} - y_{w,t,k} \right|
\end{equation}
where $T = 180$ is the prediction horizon and $K = 5$ is the number of PV channels. A detection threshold $\tau$ is set at the 99th percentile of $s_w$ computed over normal-operation windows in the validation set. A window is flagged as an attack if $s_w \geq \tau$.

This threshold is calibrated entirely on normal data — no attack labels are required — making it a zero-shot anomaly detector. Its sensitivity is inherently linked to the magnitude of the PV deviation: attacks that produce large, multi-channel residuals (such as AP\_with) are detected reliably, while stealthy attacks whose residuals overlap with the normal distribution (AP\_no, AE\_no) are harder to separate at any operationally acceptable threshold.

\paragraph{Stage 2 — Attack Type Classifier.}
To identify the specific attack family, a Random Forest classifier is trained on handcrafted statistical features extracted from the per-window PV residual trajectories. For each window, six statistics are computed independently for each of the five PV channels — mean, standard deviation, minimum, maximum, mean absolute value, and mean first difference — yielding a 30-dimensional feature vector $\mathbf{f}_w \in \mathbb{R}^{30}$.

The classifier is a Random Forest with 300 estimators and class-balanced sample weighting. Crucially, it is trained exclusively on \emph{synthetic} PV trajectories generated by the digital twin under each scenario label, with 3{,}292 windows per class to produce a balanced training set. The real test windows (with their severe class imbalance) are held out entirely and used only for evaluation. This Train-on-Real-Test-on-Synthetic (TRTS) protocol is made viable by the generation quality of the digital twin, which is independently validated in Section~\ref{sec:synth_quality}.

Algorithm~\ref{alg:detection_classification} formalises the full two-stage pipeline.

\begin{algorithm}[H]
\caption{Two-Stage Detection and Classification}
\label{alg:detection_classification}
\begin{algorithmic}[1]
\Require Trained plant model $\mathcal{M}$,
         normal validation windows $\mathcal{W}_{\text{val}}$,
         synthetic training windows $\mathcal{W}_{\text{synth}}$ (balanced, all scenarios),
         test windows $\mathcal{W}_{\text{test}}$
\Ensure Binary alert $A_w$ and attack label $\hat{s}_w$ for each test window

\Statex \textbf{--- Calibration (done once, on validation set) ---}
\For{each window $w \in \mathcal{W}_{\text{val}}$}
    \State $\hat{\mathbf{y}}_w \leftarrow \mathcal{M}(w)$
    \State $s_w \leftarrow \frac{1}{TK}\sum_{t,k}|\hat{y}_{w,t,k} - y_{w,t,k}|$
\EndFor
\State $\tau \leftarrow \text{Percentile}_{99}(\{s_w\}_{w \in \mathcal{W}_{\text{val}}})$
    \Comment{detection threshold from normal windows only}

\Statex \textbf{--- Classifier training (done once, on synthetic windows) ---}
\For{each window $w \in \mathcal{W}_{\text{synth}}$}
    \State $\mathbf{f}_w \leftarrow \text{ExtractFeatures}(w)$
    \Comment{30-dim: mean, std, min, max, mean-abs, $\Delta$ per PV channel}
\EndFor
\State $\mathcal{C} \leftarrow \text{RandomForest}(\{\mathbf{f}_w, s_w\}_{w \in \mathcal{W}_{\text{synth}}},\; n_{\text{est}}=300,\; \text{balanced})$

\Statex \textbf{--- Inference on test windows ---}
\For{each window $w \in \mathcal{W}_{\text{test}}$}
    \State $\hat{\mathbf{y}}_w \leftarrow \mathcal{M}(w)$
    \State $s_w \leftarrow \frac{1}{TK}\sum_{t,k}|\hat{y}_{w,t,k} - y_{w,t,k}|$
    \State $A_w \leftarrow \mathbf{1}[s_w \geq \tau]$
    \Comment{Stage 1: binary alert}
    \State $\mathbf{f}_w \leftarrow \text{ExtractFeatures}(w)$
    \State $\hat{s}_w \leftarrow \mathcal{C}(\mathbf{f}_w)$
    \Comment{Stage 2: attack type prediction}
\EndFor
\State \Return $\{(A_w, \hat{s}_w)\}_{w \in \mathcal{W}_{\text{test}}}$
\end{algorithmic}
\end{algorithm}
