🧾 أبسط طريقة (كل شيء دفعة واحدة)
git add .
git commit -m "your message"
git push


📌 الطريقة الكاملة (لو أول مرة أو برانش جديد)
git status                 # شو تغيّر؟
git add .                  # إضافة كل الملفات
git commit -m "message"    # كتابة وصف
git push origin main       # أو اسم البرانش تبعك


🌿 لو عندك branch
git branch                 # شو اسم البرانش؟
git push origin your-branch-name