\subsubsection{Algorithmic Description}

The complete training procedure is formalised in Algorithms 1 and 2. Algorithm 1 describes the two-stage training loop, including scheduled sampling, per-scenario loss weighting, and early stopping. Algorithm 2 describes closed-loop inference, in which trained controller models generate CV sequences that are fed into the plant model to produce the full PV prediction rollout.

\begin{algorithm}[H]
\caption{Two-Stage Digital Twin Training}
\label{alg:training}
\begin{algorithmic}[1]
\Require Dataset $\mathcal{D} = \{(X_b, Y_b, s_b)\}_{b=1}^{N}$,
         baseline checkpoint $\theta_0$,
         scenario weights $\{w_s\}$,
         stage configs $(\eta^{(1)}, E^{(1)}, P^{(1)})$,
         $(\eta^{(2)}, E^{(2)}, P^{(2)})$
\Ensure  Final model parameters $\phi^*$

\Statex \textbf{--- Stage 1: Causal Plant Training ---}
\State Initialise plant $f_\phi$ from baseline $\theta_0$;
       initialise controllers $\{g_{\psi_\ell}\}$ randomly
\State $\phi^* \leftarrow \phi$;\; $\text{best} \leftarrow \infty$;\;
       $p \leftarrow 0$

\For{$e = 1$ \textbf{to} $E^{(1)}$}
    \State $\alpha \leftarrow \text{SS-ratio}(e,\; e_{\rm start}{=}10,\;
           e_{\rm end}{=}59,\; \alpha_{\max}{=}0.483)$
           \Comment{scheduled sampling ratio}
    \For{each mini-batch $\mathcal{B} \sim \mathcal{D}$}
        \State Train controllers: $\psi_\ell \leftarrow \psi_\ell -
               \eta^{(1)}_{\rm ctrl}\,\nabla_{\psi_\ell}
               \mathcal{L}_{\rm ctrl}(\mathcal{B})$
        \State Compute plant predictions with SS ratio $\alpha$:
               $\hat{Y} = f_\phi(X, s,\, Y;\,\alpha)$
        \State Compute weighted loss (Eq.~\ref{eq:stage1_loss}):
               $w_b = 3$ if $s_b > 0$ else $1$
        \State $\phi \leftarrow \phi - \eta^{(1)}_{\rm plant}\,
               \nabla_\phi\,\mathcal{L}_{\rm plant}$
    \EndFor
    \State $v \leftarrow \text{ValidationLoss}(f_\phi,\, \mathcal{D}_{\rm val})$
    \If{$v < \text{best}$}
        \State $\phi^* \leftarrow \phi$;\; $\text{best} \leftarrow v$;\;
               $p \leftarrow 0$
    \Else
        \State $p \leftarrow p + 1$
        \If{$p \geq P^{(1)}$} \textbf{break} \EndIf
    \EndIf
    \State Update LR schedulers with $v$
\EndFor

\Statex \textbf{--- Stage 2: Per-Scenario Fine-Tuning ---}
\State Load $\phi \leftarrow \phi^*$;\;
       $\text{best} \leftarrow \infty$;\; $p \leftarrow 0$

\For{$e = 1$ \textbf{to} $E^{(2)}$}
    \State $\alpha \leftarrow \text{SS-ratio}(e,\; e_{\rm start}{=}0,\;
           e_{\rm end}{=}20,\; \alpha_{\max}{=}0.483)$
    \For{each mini-batch $\mathcal{B} \sim \mathcal{D}$}
        \State $\hat{Y} = f_\phi(X, s,\, Y;\,\alpha)$
        \State Compute per-scenario weighted loss (Eq.~\ref{eq:stage2_loss}):
               $w_b = w_{s_b}$ from Table~\ref{tab:scenario_weights}
        \State $\phi \leftarrow \phi -
               \eta^{(2)}_{\rm plant}\,\nabla_\phi\,\mathcal{L}_{\rm plant}$
    \EndFor
    \State $v \leftarrow \text{ValidationLoss}(f_\phi,\, \mathcal{D}_{\rm val})$
    \If{$v < \text{best}$}
        \State $\phi^* \leftarrow \phi$;\; $\text{best} \leftarrow v$;\;
               $p \leftarrow 0$
    \Else
        \State $p \leftarrow p + 1$
        \If{$p \geq P^{(2)}$} \textbf{break} \EndIf
    \EndIf
    \State Update LR schedulers with $v$
\EndFor
\State \Return $\phi^*$
\end{algorithmic}
\end{algorithm}

\begin{algorithm}[H]
\caption{Closed-Loop Inference}
\label{alg:inference}
\begin{algorithmic}[1]
\Require Observed sensor window $x_{cv} \in \mathbb{R}^{T_{\rm in} \times d}$,
         target CV window $x_{cv}^{\rm tgt} \in \mathbb{R}^{T \times d}$,
         initial PV $\mathbf{y}_0 \in \mathbb{R}^{n_{\rm pv}}$,
         scenario label $s \in \{0,1,2,3\}$,
         trained plant $f_{\phi^*}$,
         trained controllers $\{g_{\psi^*_\ell}\}_{\ell \in \mathcal{L}}$
\Ensure  PV prediction sequence
         $\hat{Y} = [\hat{\mathbf{y}}_1, \ldots, \hat{\mathbf{y}}_T]$

\Statex \textbf{Step 1: Controller rollout (independent, open-loop)}
\For{each loop $\ell \in \{\text{PC, LC, FC, TC, CC}\}$}
    \State $\hat{c}^\ell_{1:T} \leftarrow g_{\psi^*_\ell}(X^\ell)$
           \Comment{predict CV sequence from loop history}
    \State Inject into target window:
           $x_{cv}^{\rm tgt}[\,:,\, \text{col}(\ell)] \leftarrow \hat{c}^\ell_{1:T}$
\EndFor

\Statex \textbf{Step 2: Plant encoder}
\State $\mathbf{e}_s \leftarrow \text{Embedding}(s)$
       \Comment{scenario embedding $\in \mathbb{R}^{32}$}
\State $\mathbf{h}_0 \leftarrow \text{GRU}_{\rm enc}
       \bigl([x_{cv} \,\|\, \mathbf{e}_s]\bigr)$
       \Comment{encode observed history}

\Statex \textbf{Step 3: Autoregressive plant decoder}
\State $\mathbf{y} \leftarrow \mathbf{y}_0$
\For{$t = 1$ \textbf{to} $T$}
    \State $\mathbf{h}_t,\, \mathbf{o}_t \leftarrow
           \text{GRU}_{\rm dec}
           \bigl([x_{cv,t}^{\rm tgt} \,\|\, \mathbf{y}],\;
           \mathbf{h}_{t-1}\bigr)$
    \State $\hat{\mathbf{y}}_t \leftarrow \text{FC}(\mathbf{o}_t)$
           \Comment{project hidden state to 5 PV outputs}
    \State $\mathbf{y} \leftarrow \hat{\mathbf{y}}_t$
           \Comment{feed prediction as next decoder input}
\EndFor
\State \Return $[\hat{\mathbf{y}}_1, \ldots, \hat{\mathbf{y}}_T]$
\end{algorithmic}
\end{algorithm}


\subsubsection{Post-hoc Anomaly Detection}

Raw mean squared error (MSE) thresholding on reconstruction residuals often yields noisy, poorly calibrated alerts due to varying sensitivity across photovoltaic (PV) strings. To address this without modifying the trained forecasting model, we adopt a post-hoc detection scheme. Normal-operation validation windows are first passed through the model to collect residual feature vectors, where each vector comprises the mean squared residual computed independently for each of the five PV strings. These features serve a dual purpose: (1) they train an Isolation Forest (IF) model to capture multivariate correlations and joint anomalous behavior across the array, and (2) they establish per-PV empirical thresholds at the 99th percentile of the normal residual distribution. At test time, a window is flagged as anomalous if the Isolation Forest score exceeds a decision boundary \textit{or} if any individual PV string surpasses its specific 99th-percentile threshold, providing a robust, calibration-free alert mechanism that requires no retraining or fine-tuning of the underlying forecaster.

\begin{algorithm}[H]
\caption{Anomaly Scoring}
\label{alg:anomaly}
\begin{algorithmic}[1]
\Require Trained forecasting model $\mathcal{M}$, normal validation windows $\mathcal{W}_{\text{val}}$, test windows $\mathcal{W}_{\text{test}}$
\Ensure Binary alert $A_w$ for each test window

\Statex \textbf{Step 1: Residual Extraction}
\For{each window $w \in \mathcal{W}_{\text{val}} \cup \mathcal{W}_{\text{test}}$}
    \State Run inference with $\mathcal{M}$ to obtain predictions $\hat{\mathbf{y}}_w$
    \State Compute residual vector $\mathbf{r}_w = (\mathbf{y}_w - \hat{\mathbf{y}}_w)^2$ \Comment{element-wise squared error}
\EndFor

\Statex \textbf{Step 2: Feature Engineering}
\For{each window $w$}
    \State $\mathbf{f}_w = \big[\,\text{mean}(r_{w,\text{PV}_1}),\; \text{mean}(r_{w,\text{PV}_2}),\; \dots,\; \text{mean}(r_{w,\text{PV}_5})\,\big]$
\EndFor
\State Resulting feature matrix: $\mathbf{F} \in \mathbb{R}^{N_{\text{windows}} \times 5}$

\Statex \textbf{Step 3a: Isolation Forest Calibration}
\State Fit IsolationForest on normal validation features $\mathbf{F}_{\text{val}}$
\For{each test window feature vector $\mathbf{f}_w \in \mathbf{F}_{\text{test}}$}
    \State $s_{\text{IF}, w} = -\text{score\_samples}(\mathbf{f}_w)$
\EndFor

\Statex \textbf{Step 3b: Per-PV Thresholding}
\For{each PV string $i \in \{1,\dots,5\}$}
    \State $\tau_i = \text{Percentile}_{99}\big(\mathbf{F}_{\text{val}}[:, i]\big)$
\EndFor
\For{each test window feature vector $\mathbf{f}_w$}
    \State $\text{flag}_{\text{PV}} = \bigvee_{i=1}^{5} \big( f_{w,i} > \tau_i \big)$
\EndFor

\Statex \textbf{Step 4: Combined Alert}
\For{each test window $w$}
    \State $A_w = \mathbf{1}\big[\, s_{\text{IF}, w} > \theta_{\text{IF}} \;\lor\; \text{flag}_{\text{PV}} \,\big]$
\EndFor
\State \Return $\{A_w\}_{w \in \mathcal{W}_{\text{test}}}$
\end{algorithmic}
\end{algorithm}
